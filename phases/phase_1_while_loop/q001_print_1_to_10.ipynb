    "Question 001: Print Numbers 1 to 10\n",
    "Difficulty: Beginner | Time: 5 minutes\n",
    "\"\"\"\n",
    "\n",
    "def print_numbers():\n",
    "    i = 1\n",
    "    while i <= 10:\n",
    "        print(i)\n",
    "        i += 1\n",
